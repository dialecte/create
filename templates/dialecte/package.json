{
	"name": "__packageName__",
	"version": "0.0.1",
	"description": "Dialecte SDK for __dialecteId__",
	"license": "MIT",
	"source": "src/index.ts",
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		"./__version__": {
			"types": "./dist/__version__/index.d.ts",
			"default": "./dist/__version__/index.js"
		},
		"./__version__/test": {
			"types": "./dist/__version__/test.d.ts",
			"default": "./dist/__version__/test.js"
		}
	},
	"scripts": {
		"//====== BUILD ======//": "",
		"build": "run-p type-check \"build-only {@}\" --",
		"build-only": "tsc -p tsconfig.json && vite build",
		"//====== VITEPRESS ======//": "",
		"doc:dev": "vitepress dev docs",
		"doc:build": "vitepress build docs",
		"doc:preview": "vitepress preview docs",
		"//====== TEST ======//": "",
		"test": "vitest",
		"//====== CHECK ======//": "",
		"check": "run-p type-check type-check:test lint:check format:check",
		"type-check": "tsc --noEmit",
		"type-check:test": "tsc -p tsconfig.vitest.json --noEmit",
		"lint:check": "oxlint",
		"lint:fix": "oxlint . --fix -D correctness --ignore-path .gitignore",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt",
		"//====== TYPE PERF ======//": "",
		"coverage:gen": "dialecte coverage",
		"type-bench": "npm run coverage:gen && dialecte bench",
		"type-bench:check": "npm run coverage:gen && dialecte bench --check",
		"type-narrowing": "npm run coverage:gen && dialecte narrowing",
		"type-audit": "dialecte audit",
		"//====== HOOKS ======//": "",
		"prepare": "husky"
	},
	"dependencies": {
		"@dialecte/core": "__coreVersion__"
	},
	"devDependencies": {
		"@dialecte/cli": "0.0.1",
		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^24.12.4",
		"@vitest/browser-playwright": "^4.1.8",
		"husky": "^9.1.7",
		"npm-run-all2": "^8.0.4",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.68.0",
		"oxlint-tsgolint": "^0.23.0",
		"playwright": "^1.60.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-dts": "^5.0.2",
		"vitepress": "^2.0.0-alpha.17",
		"vitest": "^4.1.8"
	}
}
